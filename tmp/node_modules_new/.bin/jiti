#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/tmp/node_modules_new/.pnpm/jiti@2.7.0/node_modules/jiti/node_modules:/tmp/node_modules_new/.pnpm/jiti@2.7.0/node_modules:/tmp/node_modules_new/.pnpm/node_modules"
else
  export NODE_PATH="/tmp/node_modules_new/.pnpm/jiti@2.7.0/node_modules/jiti/node_modules:/tmp/node_modules_new/.pnpm/jiti@2.7.0/node_modules:/tmp/node_modules_new/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../../../../tmp/node_modules_new/.pnpm/jiti@2.7.0/node_modules/jiti/lib/jiti-cli.mjs" "$@"
else
  exec node  "$basedir/../../../../../../../../tmp/node_modules_new/.pnpm/jiti@2.7.0/node_modules/jiti/lib/jiti-cli.mjs" "$@"
fi
